# Create the .gitignore file with all necessary rules
@'
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
dist/
build/
*.egg-info/
*.egg

# Environment Variables - NEVER COMMIT!
.env
.env.local
.env.*.local
*.key
*.pem
*.crt
secrets/
credentials/

# Cache and Data
cache/
output/
logs/
*.log
*.pid

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/

# Jupyter
.ipynb_checkpoints/
*.ipynb
'@ | Out-File -FilePath .gitignore -Encoding utf8