# ============================================
# LLM Provider Configuration
# ============================================

# Choose your provider: 'ollama', 'openai', or 'gemini'
LLM_PROVIDER=ollama

# ------------------------------------------------------------
# Option 1: Ollama (Default - Free & Local)
# ------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2:1b
# Alternative models: deepseek-r1:1.5b, phi3:mini, llama3.2

# ------------------------------------------------------------
# Option 2: OpenAI (Paid - Optional)
# ------------------------------------------------------------
# OPENAI_API_KEY=sk-proj-...
# OPENAI_MODEL=gpt-4.1-mini

# ------------------------------------------------------------
# Option 3: Google Gemini (Paid - Optional)
# ------------------------------------------------------------
# GEMINI_API_KEY=AIz...
# GEMINI_MODEL=gemini-2.5-flash-lite

# ============================================
# Application Configuration
# ============================================

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Directories for output and cache
OUTPUT_DIR=output
CACHE_DIR=cache
LOG_DIR=logs

# Enable/disable caching
CACHE_ENABLED=true